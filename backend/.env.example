# --- Database ---
# For Docker Compose (default Postgres service):
DATABASE_URL=postgresql+asyncpg://mess:messpass@localhost:5432/messdb
# For local Postgres without Docker, point to your own instance.

# --- JWT ---
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=change-me-to-a-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
# JSON array; add your Flutter web origin once deployed.
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# --- Timezone (single mess, India) ---
APP_TIMEZONE=Asia/Kolkata

# --- Meal time config (24h, IST) ---
BREAKFAST_TIME=08:00
LUNCH_TIME=12:00
DINNER_TIME=20:00
# Breakfast cutoff = previous day at this time.
BREAKFAST_SKIP_CUTOFF=22:00
# Lunch/dinner cutoff = N hours before the meal.
LUNCH_SKIP_CUTOFF_HOURS=4
DINNER_SKIP_CUTOFF_HOURS=4

# --- Bootstrap admin (used by seed.py) ---
# Note: must be a valid email (e.g. .com/.org/.in). Reserved TLDs like .local are rejected by EmailStr.
ADMIN_EMAIL=admin@mess.example
# Leave blank to have seed.py print a generated password to stdout once.
ADMIN_PASSWORD=
